---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

const echoes = [
	['HEAT', '扩散直觉', '热方程提供最干净的扩散图像：局部差异会随时间被平滑。'],
	['WAVE', '传播直觉', '波动模型提醒我们能量也可能以传播和振动的方式出现。'],
	['PSEUDO', '拟抛物结构', '时间项和空间导数耦合后，演化过程带上了非标准记忆感。'],
	['WEIGHT', '非均匀介质', '奇异权可以被看作一种抽象的空间不均匀信号。'],
];
---

<html lang="zh-CN">
	<head>
		<BaseHead title="Signal Echo | SKS Research Lab" description={SITE_DESCRIPTION} />
		<style>
			.echo-hero {
				margin-bottom: 2rem;
				padding: 1.5rem;
			}
			.echo-hero h1 { font-size: 3.4rem; }
			.echo-hero p { max-width: 48rem; color: var(--text-secondary); }
			.echo-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}
			.echo-card {
				min-height: 11rem;
				padding: 1.2rem;
			}
			.echo-card p { color: var(--text-muted); }
			@media (max-width: 760px) {
				.echo-grid { grid-template-columns: 1fr; }
				.echo-hero h1 { font-size: 2.55rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="echo-hero hud-card">
				<p class="eyebrow">SIGNAL ECHO / 物理直觉</p>
				<h1>Signal Echo</h1>
				<p>
					这里不写严格物理理论，只保留帮助理解 PDE 的模型直觉：
					扩散、传播、记忆项和空间非均匀性。
				</p>
			</section>

			<section class="echo-grid" aria-label="物理直觉">
				{echoes.map(([code, title, text]) => (
					<article class="echo-card hud-card">
						<span class="meta-code">{code}</span>
						<h2>{title}</h2>
						<p>{text}</p>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
