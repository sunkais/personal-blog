---
import { NEXUS_URL } from '../consts';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

const projects = [
	['NEXUS NODE', 'Nexus Node / 小屋接口', '外部作品与个人空间节点，保留小屋、作品上传和小游戏入口。', NEXUS_URL],
	['WEB-LAB', 'SKS Research Lab', '当前站点本身也是实验：隐私降噪、内容整理和蓝白电磁抽象视觉。', '/'],
	['TEX-SYS', 'LaTeX 研究工具链', '围绕文献、公式、引用和编译日志形成的低噪声写作流程。', '/ai'],
	['MINI GAME', 'Mini Game Lab', '交互原型与小游戏入口，给研究终端留一点可点击的能量。', NEXUS_URL],
	['NUMERIC', '数值实验直观', '用轻量脚本观察能量路径和参数变化，只负责提供直觉。', '/blog/numerical-glimpse/'],
	['UPLOAD', '作品上传入口', '更偏向 Nexus 的功能节点，主站只保留清晰入口。', NEXUS_URL],
];
---

<html lang="zh-CN">
	<head>
		<BaseHead title="Projects | SKS Research Lab" description={SITE_DESCRIPTION} />
		<style>
			.project-hero {
				margin-bottom: 2rem;
				padding: 1.5rem;
			}
			.project-hero h1 { font-size: 3.4rem; }
			.project-hero p { max-width: 48rem; color: var(--text-secondary); }
			.project-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}
			.project-card {
				display: flex;
				flex-direction: column;
				gap: 0.55rem;
				min-height: 13rem;
				padding: 1.2rem;
				color: var(--text-primary);
				text-decoration: none;
			}
			.project-card p { color: var(--text-muted); }
			.project-card .open {
				margin-top: auto;
				color: var(--electric-soft);
			}
			@media (max-width: 860px) {
				.project-grid { grid-template-columns: 1fr; }
				.project-hero h1 { font-size: 2.55rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="project-hero hud-card">
				<p class="eyebrow">NEXUS-04 / 小屋接口</p>
				<h1>Projects</h1>
				<p>
					这里是项目入口，不做正式作品集。个人网站、Nexus、工具链、数值直观和小游戏都作为实验节点存在。
				</p>
			</section>

			<section class="project-grid" aria-label="项目入口">
				{projects.map(([code, title, text, href]) => (
					<a class="project-card hud-card" href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noreferrer' : undefined}>
						<span class="meta-code">{code}</span>
						<h2>{title}</h2>
						<p>{text}</p>
						<span class="open meta-code">OPEN</span>
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
