---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Formula from '../components/Formula.astro';
import { NEXUS_URL, SITE_DESCRIPTION, SITE_NAME_EN, SITE_NAME_CN, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const notes = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const corners = [
	{
		title: '数学一隅',
		description: '偏微分方程、奇异项、Galerkin 方法、变分法与 Sobolev 空间。',
		href: '/math',
	},
	{
		title: '物理回声',
		description: '从热方程、波方程到伪抛物方程，整理方程背后的物理直觉与模型来源。',
		href: '/physics',
	},
	{
		title: 'AI 手札',
		description: 'Codex、Claude Code、GitHub Copilot、LaTeX 自动化与 AI 辅助写作工作流。',
		href: '/ai',
	},
	{
		title: '论文书桌',
		description: '硕士论文、文献整理、证明细节、盲审修改和答辩材料。',
		href: '/thesis',
	},
	{
		title: '项目小径',
		description: 'sunkais.com、Nexus 像素舱和慢慢生长的小项目。',
		href: '/projects',
	},
	{
		title: '生活碎片',
		description: '游戏、毕业、审美、计划，以及重建生活的记录。',
		href: '/about',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-main">
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">{SITE_NAME_EN}</p>
					<h1>{SITE_NAME_CN}</h1>
					<p class="hero-lead">{SITE_DESCRIPTION}</p>
					<p class="hero-note">
						这里记录数学、物理、AI 工具、硕士论文、个人项目，以及慢慢生长的生活。它不需要像教授主页那样严肃，也不需要像赛博站那样用力；更像一本安静翻开的笔记。
					</p>
					<div class="button-row">
						<a class="button primary" href="/blog">进入笔记</a>
						<a class="button" href="/thesis">论文书桌</a>
						<a class="button" href={NEXUS_URL} target="_blank" rel="noreferrer">访问 Nexus ↗</a>
					</div>
				</div>

				<aside class="desk-area" aria-label="书桌角落">
					<div class="desk-photo-wrapper">
						<div class="desk-photo">
							<div class="photo-frame" aria-label="书桌上的一张个人相片">
								<img class="photo-img" src="/avatar.jpg" alt="孙开松" loading="eager" />
							</div>
							<div class="photo-label">书桌一角</div>
							<div class="tape tape-top"></div>
							<div class="tape tape-bottom"></div>
						</div>
					</div>
					<div class="desk-card paper-card">
						<p class="desk-kicker">今日书桌</p>
						<div class="desk-formula">
							<Formula math="-\Delta u = \\frac{|u|^{p-2}u}{|x|^s}" displayMode={true} />
						</div>
						<p class="desk-context">
							正在整理：硕士论文答辩材料、Galerkin 方法笔记、Nexus 页面优化。
						</p>
						<p class="desk-keywords">
							当前关键词：奇异项、伪抛物方程、Codex、LaTeX、个人网站。
						</p>
					</div>
				</aside>
			</section>

			<section class="corners" aria-labelledby="corners-title">
				<div class="section-heading">
					<p class="eyebrow">Quiet Corners</p>
					<h2 id="corners-title">几个安静的角落</h2>
				</div>
				<div class="corner-grid">
					{corners.map((corner) => (
						<a class="corner-card paper-card" href={corner.href}>
							<span>{corner.title}</span>
							<p>{corner.description}</p>
						</a>
					))}
				</div>
			</section>

			<section class="recent-notes" aria-labelledby="notes-title">
				<div class="section-heading">
					<p class="eyebrow">Notes</p>
					<h2 id="notes-title">最近整理</h2>
				</div>
				<div class="note-strip">
					{notes.map((note) => (
						<a class="note-link" href={`/blog/${note.id}/`}>
							<span>{note.data.title}</span>
							<small>{note.data.description}</small>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.home-main {
		padding-top: 4rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.72fr);
		align-items: start;
		gap: 3rem;
		min-height: 70vh;
		padding: 2rem 0 5rem;
	}

	.hero-copy {
		min-width: 0;
	}

	.hero h1 {
		margin-bottom: 0.45rem;
		font-family: Georgia, "Times New Roman", serif;
		font-weight: 700;
	}

	.hero-lead {
		max-width: 37rem;
		color: var(--leaf-dark);
		font-size: 1.28rem;
		font-weight: 700;
		line-height: 1.6;
		overflow-wrap: anywhere;
	}

	.hero-note {
		max-width: 42rem;
		color: var(--muted);
		overflow-wrap: anywhere;
	}

	.desk-area {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		min-width: 0;
	}

	.desk-photo-wrapper {
		display: flex;
		justify-content: center;
	}

	.desk-photo {
		position: relative;
		width: 170px;
		transform: rotate(2.5deg);
		transition: transform 260ms ease;
	}

	.desk-photo:hover {
		transform: rotate(0deg);
	}

	.photo-frame {
		padding: 0.45rem;
		border: 1px solid var(--line);
		border-radius: 3px;
		background: var(--paper-warm);
		box-shadow:
			0 2px 8px rgba(76, 65, 45, 0.1),
			0 8px 24px rgba(76, 65, 45, 0.06);
	}

	.photo-img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 4;
		object-fit: cover;
		border-radius: 1px;
	}

	.photo-label {
		margin-top: 0.55rem;
		color: var(--soft-muted);
		font-size: 0.76rem;
		text-align: center;
		line-height: 1;
	}

	.tape {
		position: absolute;
		height: 1.1rem;
		background: rgba(236, 228, 214, 0.5);
		border-radius: 1px;
	}

	.tape-top {
		top: -0.25rem;
		left: 50%;
		width: 3.2rem;
		transform: translateX(-50%) rotate(-1.5deg);
	}

	.tape-bottom {
		bottom: 1.5rem;
		left: 50%;
		width: 3.8rem;
		transform: translateX(-50%) rotate(1deg);
	}

	.desk-card {
		position: relative;
		min-width: 0;
		padding: 1.55rem;
		overflow: hidden;
	}

	.desk-card::before {
		position: absolute;
		top: 1.1rem;
		right: 1.2rem;
		color: var(--leaf);
		content: "\222B  \3A9";
		font-family: Georgia, "Times New Roman", serif;
		font-size: 3.8rem;
		opacity: 0.1;
		pointer-events: none;
	}

	.desk-kicker {
		margin-bottom: 1rem;
		color: var(--leaf-dark);
		font-weight: 700;
	}

	.desk-formula {
		margin: 0 0 0.9rem;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid var(--line);
		overflow-x: auto;
	}

	.desk-formula :global(.katex) {
		font-size: 1.15rem;
	}

	.desk-context {
		margin-bottom: 0.5rem;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.desk-keywords {
		color: var(--soft-muted);
		font-size: 0.84rem;
		line-height: 1.55;
	}

	.corners,
	.recent-notes {
		padding: 4rem 0 0;
	}

	.section-heading {
		max-width: 38rem;
		margin-bottom: 1.5rem;
	}

	.section-heading h2 {
		margin-bottom: 0.35rem;
	}

	.corner-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.corner-card {
		min-height: 10rem;
		padding: 1.2rem;
		color: var(--ink);
		text-decoration: none;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.corner-card:hover {
		border-color: var(--leaf);
		box-shadow: var(--shadow);
		color: var(--ink);
		transform: translateY(-3px);
	}

	.corner-card span {
		display: block;
		margin-bottom: 0.6rem;
		color: var(--leaf-dark);
		font-size: 1.08rem;
		font-weight: 700;
	}

	.corner-card p {
		margin: 0;
		color: var(--muted);
		font-size: 0.94rem;
		line-height: 1.65;
	}

	.note-strip {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.note-link {
		display: grid;
		gap: 0.45rem;
		padding: 1rem 0;
		border-top: 1px solid var(--line);
		color: var(--ink);
		text-decoration: none;
	}

	.note-link span {
		font-weight: 700;
	}

	.note-link small {
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.note-link:hover span {
		color: var(--leaf-dark);
	}

	@media (max-width: 980px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.desk-area {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 1.25rem;
			align-items: start;
		}

		.desk-photo {
			width: 135px;
		}

		.corner-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.note-strip {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.home-main {
			padding-top: 2rem;
		}

		.hero {
			gap: 2rem;
			padding-bottom: 3rem;
		}

		.hero-lead {
			font-size: 1.12rem;
		}

		.desk-area {
			grid-template-columns: 1fr;
		}

		.desk-photo-wrapper {
			justify-content: flex-start;
		}

		.desk-photo {
			width: 120px;
		}

		.corner-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
