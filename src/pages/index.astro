---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Formula from '../components/Formula.astro';
import Header from '../components/Header.astro';
import { NEXUS_URL, SITE_DESCRIPTION, SITE_SUBTITLE, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
const randomNote = posts.length ? posts[new Date().getDate() % posts.length] : undefined;
const todaySignalMath = String.raw`-\Delta u=|x|^{-s_2}|u|^{p-2}u.`;

const archiveCards = [
	['ARCHIVE-01', '双奇异权拟抛物方程', '把时间项、扩散项和两个奇异权放在同一个模型里，先确认研究对象的边界。'],
	['ROUTE-02', '局部解证明路线', '用 Galerkin 近似、截断权函数和能量估计，把无限维问题压成可控信号。'],
	['CORE-03', 'Mountain Pass 稳态解', '从能量泛函的几何结构出发，寻找山口水平上的非平凡稳态。'],
	['METHOD-04', 'Galerkin 方法', '选择特征函数基，把抽象空间里的演化方程拆成有限维常微分方程组。'],
	['SIGNAL-05', '奇异权解释', '原点附近的权重像异常噪声，证明需要同时照顾可积性和边界条件。'],
	['GLIMPSE-06', '数值实验直观', '不替代证明，只用图像帮助判断能量、扩散和增长项的相互拉扯。'],
];

const labCards = [
	['WORKFLOW', 'AI 文献整理工作流', '把文献摘要、证明线索和待验证命题拆成可回溯的研究记录。', '/ai'],
	['TEX-SYS', 'LaTeX 研究系统', '模板、公式、引用和编译流程尽量自动化，减少手工噪声。', '/ai'],
	['WEB-LAB', '个人网站实验', '这个站点本身也是实验：路由、内容、视觉和隐私边界都在迭代。', '/projects'],
	['NEXUS-04', 'Nexus 小屋', '一个更生活化的外部节点，保留作品上传和个人空间的入口。', NEXUS_URL],
	['GAME-05', 'Mini Game Lab', '小游戏与交互原型存放区，让抽象实验偶尔变得可点击。', '/projects'],
];
---

<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero-lab {
				display: grid;
				grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
				align-items: stretch;
				gap: 1.2rem;
				min-height: calc(100vh - 8rem);
				min-width: 0;
				padding: 2rem 0 3rem;
			}

			.hero-copy {
				display: flex;
				flex-direction: column;
				justify-content: center;
				min-width: 0;
				padding: 2rem 0;
			}

			.hero-kicker {
				display: inline-flex;
				width: fit-content;
				margin-bottom: 1.1rem;
				padding: 0.32rem 0.62rem;
				border: 1px solid var(--glass-border);
				border-radius: 999px;
				background: rgba(15, 23, 42, 0.58);
			}

			.hero-copy h1 {
				margin-bottom: 0.55rem;
				background: linear-gradient(135deg, var(--text-bright) 8%, var(--electric-soft) 52%, var(--violet) 100%);
				-webkit-background-clip: text;
				background-clip: text;
				color: transparent;
				font-size: 4.7rem;
				letter-spacing: 0;
			}

			.hero-subtitle {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem 0.55rem;
				margin-bottom: 1.35rem;
				color: var(--electric-soft);
				font-family: "Courier New", "Consolas", monospace;
				font-size: 1rem;
				letter-spacing: 0.08em;
				overflow-wrap: anywhere;
				white-space: normal;
				word-break: break-word;
			}

			.hero-subtitle span,
			.lab-tagline span {
				display: inline-flex;
				align-items: center;
			}

			.hero-subtitle span:not(:last-child)::after,
			.lab-tagline span:not(:last-child)::after {
				margin-left: 0.55rem;
				color: var(--text-muted);
				content: "/";
			}

			.hero-copy p {
				max-width: 45rem;
				color: var(--text-secondary);
				font-size: 1.08rem;
				overflow-wrap: anywhere;
			}

			.lab-tagline {
				display: flex;
				flex-wrap: wrap;
				gap: 0.35rem 0.55rem;
			}

			.lab-tagline span:not(:last-child)::after {
				content: "·";
			}

			.hero-panel {
				display: flex;
				align-items: stretch;
				justify-content: center;
				min-width: 0;
				padding: 1.2rem;
			}

			.signal-card {
				display: grid;
				width: 100%;
				min-height: 30rem;
				min-width: 0;
				padding: 1.2rem;
				overflow: hidden;
			}

			.signal-card::after {
				position: absolute;
				right: -3rem;
				bottom: -3rem;
				width: 16rem;
				height: 16rem;
				border: 1px solid rgba(128, 237, 255, 0.18);
				border-radius: 50%;
				background: radial-gradient(circle, rgba(76, 201, 240, 0.12), transparent 66%);
				content: "";
			}

			.signal-inner {
				position: relative;
				z-index: 1;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				gap: 1.2rem;
			}

			.signal-label {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				color: var(--text-muted);
			}

			.formula-core {
				margin: 1.4rem 0;
			}

			.signal-notes {
				display: grid;
				gap: 0.58rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}

			.signal-notes li {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				padding: 0.72rem 0;
				border-bottom: 1px solid var(--glass-border-soft);
				color: var(--text-secondary);
			}

			.signal-notes span:first-child {
				color: var(--electric-soft);
				font-family: "Courier New", "Consolas", monospace;
				font-size: 0.78rem;
				letter-spacing: 0.12em;
			}

			.lab-section {
				margin-top: 3rem;
			}

			.archive-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}

			.archive-grid .hud-card,
			.lab-grid .hud-card {
				display: flex;
				flex-direction: column;
				gap: 0.55rem;
				min-height: 12rem;
			}

			.archive-grid h3,
			.lab-grid h3 {
				font-size: 1.13rem;
			}

			.archive-grid p,
			.lab-grid p {
				color: var(--text-muted);
				font-size: 0.96rem;
			}

			.lab-grid {
				display: grid;
				grid-template-columns: repeat(5, minmax(0, 1fr));
				gap: 1rem;
			}

			.record-arrow {
				color: var(--electric-soft);
				font-family: "Courier New", "Consolas", monospace;
			}

			@media (max-width: 980px) {
				.hero-lab {
					grid-template-columns: 1fr;
					min-height: auto;
					padding-top: 1rem;
				}
				.hero-panel { padding: 0; }
				.hero-copy h1 { font-size: 3.2rem; }
				.archive-grid,
				.lab-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
			}

			@media (max-width: 640px) {
				.hero-copy { padding: 0.5rem 0 1rem; }
				.hero-copy h1 { font-size: 2.35rem; }
				.hero-subtitle { font-size: 0.86rem; }
				.hero-copy .status-line {
					white-space: normal;
					word-break: break-all;
					overflow-wrap: anywhere;
				}
				.hero-copy p {
					font-size: 1rem;
					word-break: break-all;
				}
				.hero-copy .button-row {
					display: grid;
					grid-template-columns: 1fr;
				}
				.hero-copy .button {
					width: 100%;
				}
				.signal-card { min-height: auto; }
				.signal-label {
					flex-direction: column;
					gap: 0.25rem;
				}
				.archive-grid,
				.lab-grid { grid-template-columns: 1fr; }
				.signal-notes li {
					flex-direction: column;
					gap: 0.15rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero-lab">
				<div class="hero-copy">
					<div class="hero-kicker meta-code">SIGNAL-00 / 入口信号</div>
					<h1>SKS Research Lab</h1>
					<div class="hero-subtitle">
						<span>异常数学实验室</span>
						<span>PDE Notes</span>
						<span>AI Workflow</span>
						<span>Mini Lab</span>
					</div>
					<p>
						这里不是简历站，也不是论文下载站。
						这里是一个半匿名数学研究终端：存放拟抛物方程、奇异项、Galerkin、Mountain Pass、AI 工作流和一些抽象实验。
					</p>
					<div class="status-line lab-tagline">
						<span>数学笔记</span>
						<span>抽象实验</span>
						<span>PDE 档案</span>
						<span>AI 工作流</span>
					</div>
					<div class="button-row">
						<a class="button primary" href="/thesis">进入研究档案</a>
						<a class="button" href="/thesis#equation-core">查看公式核心</a>
						<a class="button" href={NEXUS_URL} target="_blank" rel="noreferrer">打开 Nexus</a>
						{randomNote && <a class="button" href={`/blog/${randomNote.id}/`}>随机进入一条笔记</a>}
					</div>
				</div>

				<div class="hero-panel">
					<aside class="signal-card" aria-label="今日信号卡片">
						<div class="signal-inner">
							<div>
								<div class="signal-label">
									<span class="meta-code">FORMULA-02 / 公式核心</span>
									<span class="meta-code">NOISE: LOW</span>
								</div>
								<h2>今日信号</h2>
								<div class="formula-panel formula-core">
									<Formula math={todaySignalMath} displayMode={true} />
								</div>
							</div>
							<ul class="signal-notes">
								<li><span>STATUS</span><strong>STABLE</strong></li>
								<li><span>TYPE</span><strong>STEADY_STATE</strong></li>
								<li><span>NOTE</span><strong>时间导数已关闭，山路仍在。</strong></li>
							</ul>
						</div>
					</aside>
				</div>
			</section>

			<section class="lab-section" aria-labelledby="archive-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">ARCHIVE-01 / 研究档案</p>
						<h2 id="archive-title">异常数学档案</h2>
					</div>
					<p>不要下载成稿，这里只泄露思路。把证明路线拆成可读信号，再慢慢接回严谨的数学语言。</p>
				</div>
				<div class="archive-grid">
					{archiveCards.map(([code, title, text]) => (
						<a class="hud-card" href="/thesis">
							<span class="meta-code">{code}</span>
							<h3>{title}</h3>
							<p>{text}</p>
						</a>
					))}
				</div>
			</section>

			<section class="lab-section" aria-labelledby="lab-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">CHAOS-03 / 抽象实验</p>
						<h2 id="lab-title">蓝白实验区</h2>
					</div>
					<p>AI、LaTeX、个人网站和小游戏都放在这里。公式稳定，精神状态未知。</p>
				</div>
				<div class="lab-grid">
					{labCards.map(([code, title, text, href]) => (
						<a class="hud-card" href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noreferrer' : undefined}>
							<span class="meta-code">{code}</span>
							<h3>{title}</h3>
							<p>{text}</p>
						</a>
					))}
				</div>
			</section>

			<section class="lab-section" aria-labelledby="records-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">LOG-05 / 最近记录</p>
						<h2 id="records-title">研究信号流</h2>
					</div>
					<p>最近五条笔记优先展示研究对象、证明路线和工作流，不展示过度私人的履历信息。</p>
				</div>
				<ul class="record-list">
					{posts.map((post) => (
						<li>
							<a class="record-link" href={`/blog/${post.id}/`}>
								<span class="meta-code"><FormattedDate date={post.data.pubDate} /></span>
								<span>{post.data.title}</span>
								<span class="record-arrow">OPEN</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
