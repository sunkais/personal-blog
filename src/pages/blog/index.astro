---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="笔记集合 | 松间笔记" description="数学、物理、AI 工具与论文写作的个人笔记，持续生长中。" />
	</head>
	<body>
		<Header />
		<main class="notes-main">
			<section class="notes-hero">
				<p class="eyebrow">Notes</p>
				<h1>笔记集合</h1>
				<p>
					这里放着正在生长的数学笔记、物理直觉和 AI 工作流记录。它们不是教材，也不是教程——更像是书桌上的草稿本：有完成的片段，有正在推敲的论证，也有随手记下的问题。
				</p>
			</section>

			<section class="note-list" aria-label="全部笔记">
				{
					posts.map((post) => (
						<a class="note-card paper-card" href={`/blog/${post.id}/`}>
							<div>
								<p class="note-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
							</div>
							<span>阅读全文</span>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.notes-main {
		width: min(920px, calc(100% - 2rem));
	}

	.notes-hero {
		max-width: 42rem;
		margin-bottom: 2rem;
	}

	.notes-hero h1 {
		font-family: Georgia, "Times New Roman", serif;
		font-size: 3.8rem;
	}

	.notes-hero p:not(.eyebrow) {
		color: var(--muted);
	}

	.note-list {
		display: grid;
		gap: 1rem;
	}

	.note-card {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1.2rem;
		color: var(--ink);
		text-decoration: none;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			box-shadow 160ms ease;
	}

	.note-card:hover {
		border-color: var(--leaf);
		box-shadow: var(--shadow);
		color: var(--ink);
		transform: translateY(-2px);
	}

	.note-date {
		margin-bottom: 0.35rem;
		color: var(--soft-muted);
		font-size: 0.92rem;
	}

	.note-card h2 {
		margin-bottom: 0.45rem;
		font-size: 1.35rem;
	}

	.note-card p {
		margin-bottom: 0;
		color: var(--muted);
	}

	.note-card span {
		flex: 0 0 auto;
		color: var(--leaf-dark);
		font-size: 0.9rem;
		font-weight: 700;
	}

	@media (max-width: 720px) {
		.notes-main {
			width: min(100% - 1.25rem, 920px);
		}

		.notes-hero h1 {
			font-size: 3rem;
		}

		.note-card {
			align-items: flex-start;
			flex-direction: column;
			gap: 1rem;
		}
	}
</style>
