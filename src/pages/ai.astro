---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

const workflows = [
	['CODEX', 'Codex 文献整理', '抽取题录、统一引用、标记 needs_review，把文献文件整理成可复查清单。'],
	['TEX', 'LaTeX 自动化', '检查公式环境、引用键、编译日志和符号一致性，减少重复劳动。'],
	['WEB', '网站迭代', '读取项目结构、同步页面风格、保持构建稳定，把模板痕迹降到低噪声。'],
	['BOUNDARY', '辅助边界', 'AI 负责整理和检查，人负责判断、证明和最终内容。'],
];
---

<html lang="zh-CN">
	<head>
		<BaseHead title="AI Workflow | SKS Research Lab" description={SITE_DESCRIPTION} />
		<style>
			.workflow-hero {
				margin-bottom: 2rem;
				padding: 1.5rem;
			}
			.workflow-hero h1 { font-size: 3.4rem; }
			.workflow-hero p { max-width: 48rem; color: var(--text-secondary); }
			.workflow-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}
			.workflow-card {
				min-height: 12rem;
				padding: 1.2rem;
			}
			.workflow-card p { color: var(--text-muted); }
			@media (max-width: 760px) {
				.workflow-grid { grid-template-columns: 1fr; }
				.workflow-hero h1 { font-size: 2.55rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="workflow-hero hud-card">
				<p class="eyebrow">SIGNAL ROOM / AI Workflow</p>
				<h1>AI Workflow</h1>
				<p>
					这里记录 AI 辅助研究写作、LaTeX 自动化、文献整理和网站开发的实际流程。
					工具像终端灯光，只照亮材料，不替代判断。
				</p>
			</section>

			<section class="workflow-grid" aria-label="AI 工作流">
				{workflows.map(([code, title, text]) => (
					<article class="workflow-card hud-card">
						<span class="meta-code">{code}</span>
						<h2>{title}</h2>
						<p>{text}</p>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
