---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Formula from '../components/Formula.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

const modules = [
	['Equation Core', '主方程', '拟抛物结构、时间导数扩散和源项在这里汇合，是整条档案的起点。'],
	['Double Singularity', '双奇异结构', '两个权函数分别作用在时间项和非线性项上，靠近原点时会放大估计难度。'],
	['Local Solution Route', '局部解路线', 'Galerkin 近似、截断、紧性和能量控制组成一条可验证路线。'],
	['Steady State Route', '稳态解路线', '关闭时间导数后，问题进入变分框架，用 Mountain Pass 寻找非平凡解。'],
	['Numerical Glimpse', '数值直观', '图像只负责给直觉供电，不替代证明。'],
	['Glossary Node', '术语节点', '把 Sobolev 空间、Nehari 流形、弱形式等关键词压缩成可复查短条目。'],
];

const mainEquation = String.raw`\begin{cases}
|x|^{-s_1}u_t-\Delta u_t-\Delta u
=
|x|^{-s_2}|u|^{p-2}u,
& (x,t)\in \Omega\times(0,T),\\
u(x,0)=u_0(x),
& x\in\Omega,\\
u(x,t)=0,
& (x,t)\in\partial\Omega\times(0,T).
\end{cases}`;

const parameterCondition = String.raw`0\le s_1\le 2,\qquad
2N+p-pN\le s_2\le N+p-\frac12pN,\qquad
2<p\le \frac{2N}{N-1}.`;

const steadyEquation = String.raw`\begin{cases}
-\Delta u=|x|^{-s_2}|u|^{p-2}u,
& x\in\Omega,\\
u=0,
& x\in\partial\Omega.
\end{cases}`;
---

<html lang="zh-CN">
	<head>
		<BaseHead title="Research Archive | SKS Research Lab" description={SITE_DESCRIPTION} />
		<style>
			.archive-hero {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(300px, 0.72fr);
				gap: 1rem;
				margin-bottom: 2.5rem;
			}

			.archive-hero .hud-card {
				padding: 1.4rem;
			}

			.archive-hero h1 {
				margin-bottom: 0.25rem;
				font-size: 3.8rem;
			}

			.archive-hero h2 {
				margin-bottom: 1.2rem;
				color: var(--electric-soft);
				font-family: "Courier New", "Consolas", monospace;
				font-size: 1.05rem;
				letter-spacing: 0.08em;
			}

			.archive-hero p,
			.module-card p {
				color: var(--text-secondary);
			}

			.archive-meta {
				display: grid;
				gap: 0.65rem;
			}

			.archive-meta div {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				padding-bottom: 0.55rem;
				border-bottom: 1px solid var(--glass-border-soft);
			}

			.archive-meta span:first-child {
				color: var(--electric-soft);
				font-family: "Courier New", "Consolas", monospace;
				font-size: 0.78rem;
				letter-spacing: 0.12em;
			}

			.module-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
				margin-bottom: 2.5rem;
			}

			.module-card {
				padding: 1.15rem;
			}

			.module-card h3 {
				margin-bottom: 0.25rem;
			}

			.equation-stack {
				display: grid;
				gap: 1rem;
			}

			.equation-block {
				padding: 1.25rem;
			}

			.equation-block p {
				color: var(--text-muted);
			}

			.route-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				margin-top: 1rem;
			}

			.route-grid .hud-card {
				padding: 1.15rem;
			}

			@media (max-width: 860px) {
				.archive-hero,
				.module-grid,
				.route-grid {
					grid-template-columns: 1fr;
				}
				.archive-hero h1 { font-size: 2.7rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-hero">
				<div class="hud-card">
					<p class="eyebrow">ARCHIVE NODE / PRIVACY LOW</p>
					<h1>Research Archive</h1>
					<h2>研究档案</h2>
					<p>
						这里不放正式成稿，也不展示正式封面。
						这里只保留研究思路：模型、困难、证明路线、变分结构和数值直观。
					</p>
					<div class="tag-row" aria-label="研究关键词">
						<span class="tag">PDE</span>
						<span class="tag">Singular Weights</span>
						<span class="tag">Galerkin</span>
						<span class="tag">Mountain Pass</span>
						<span class="tag hot">NOISE: LOW</span>
					</div>
				</div>
				<aside class="hud-card archive-meta" aria-label="档案状态">
					<div><span>STATUS</span><strong>ACTIVE</strong></div>
					<div><span>TYPE</span><strong>PDE_ARCHIVE</strong></div>
					<div><span>ACCESS</span><strong>NOTES ONLY</strong></div>
					<div><span>ENERGY</span><strong>STABLE</strong></div>
				</aside>
			</section>

			<section class="module-grid" aria-label="研究档案模块">
				{modules.map(([en, cn, text]) => (
					<article class="module-card hud-card">
						<span class="meta-code">{en}</span>
						<h3>{cn}</h3>
						<p>{text}</p>
					</article>
				))}
			</section>

			<section id="equation-core" class="equation-stack" aria-labelledby="equation-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">FORMULA-02 / Equation Core</p>
						<h2 id="equation-title">主方程</h2>
					</div>
					<p>把混乱压缩进 Sobolev 空间之前，先把模型写清楚。</p>
				</div>

				<article class="equation-block hud-card">
					<h3>主方程</h3>
					<div class="formula-panel">
						<Formula math={mainEquation} displayMode={true} />
					</div>
					<p>两个奇异权分别进入时间项与源项。难点不是只在方程长，而是每一项都需要和函数空间、边界条件、紧性估计对齐。</p>
				</article>

				<article class="equation-block hud-card">
					<h3>参数条件</h3>
					<div class="formula-panel">
						<Formula math={parameterCondition} displayMode={true} />
					</div>
					<p>这些限制让奇异权、非线性增长和 Sobolev 嵌入保持在可估计范围内。</p>
				</article>

				<article class="equation-block hud-card">
					<h3>稳态方程</h3>
					<div class="formula-panel">
						<Formula math={steadyEquation} displayMode={true} />
					</div>
					<p>时间导数关闭后，山路开始出现：能量泛函、路径类和 Nehari 流形会成为主要工具。</p>
				</article>
			</section>

			<section class="lab-section" aria-labelledby="route-title">
				<div class="section-header">
					<div>
						<p class="eyebrow">ROUTE MAP / Proof Signal</p>
						<h2 id="route-title">证明路线</h2>
					</div>
					<p>只保留研究路线，不展示正式材料。</p>
				</div>
				<div class="route-grid">
					<a class="hud-card" href="/blog/local-solution-proof/">
						<span class="meta-code">LOCAL_ROUTE</span>
						<h3>Galerkin：把无限维压成有限维</h3>
						<p>弱形式、特征函数、截断权函数和局部解能量估计。</p>
					</a>
					<a class="hud-card" href="/blog/mountain-pass-steady-state/">
						<span class="meta-code">STEADY_ROUTE</span>
						<h3>Mountain Pass：能量地形里的山口</h3>
						<p>能量泛函、路径类、山口水平和 Nehari 流形。</p>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
