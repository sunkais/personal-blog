---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Formula from '../components/Formula.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';

const topics = [
	['PDE_CORE', '偏微分方程', '拟抛物结构、扩散项、边界条件和弱解框架，是研究档案的基础信号。'],
	['GALERKIN', 'Galerkin 方法', '用特征函数空间近似无限维问题，再通过一致估计和紧性工具取极限。'],
	['VARIATION', '变分法', '把稳态方程转换成能量泛函的临界点问题，观察山口几何。'],
	['SOBOLEV', 'Sobolev 空间', '控制梯度、边界条件和嵌入定理，让非线性项留在可估计范围内。'],
	['WEIGHT', '奇异权', '靠近原点时权重增强，证明需要处理可积性、截断和加权估计。'],
	['NUMERIC', '数值直观', '图像只提供直觉，不替代严格证明。'],
];

const energyFunctional = String.raw`J(u)=\frac12\|\nabla u\|_2^2
-\frac1p\int_\Omega |x|^{-s_2}|u|^p\,dx.`;
---

<html lang="zh-CN">
	<head>
		<BaseHead title="Formula Lab | SKS Research Lab" description={SITE_DESCRIPTION} />
		<style>
			.page-hero {
				margin-bottom: 2rem;
				padding: 1.5rem;
			}
			.page-hero h1 { font-size: 3.4rem; }
			.page-hero p { max-width: 48rem; color: var(--text-secondary); }
			.topic-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
			}
			.topic-card {
				min-height: 12rem;
				padding: 1.15rem;
			}
			.topic-card p { color: var(--text-muted); }
			.quick-core { margin-top: 2rem; padding: 1.25rem; }
			@media (max-width: 860px) {
				.topic-grid { grid-template-columns: 1fr; }
				.page-hero h1 { font-size: 2.55rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-hero hud-card">
				<p class="eyebrow">FORMULA LAB / 数学信号室</p>
				<h1>Formula Lab</h1>
				<p>
					这里整理 PDE、Galerkin、Sobolev、变分法和奇异权的基础笔记。
					目标不是把材料堆满，而是把常用工具压缩成能重新读懂的研究信号。
				</p>
			</section>

			<section class="topic-grid" aria-label="数学主题">
				{topics.map(([code, title, text]) => (
					<article class="topic-card hud-card">
						<span class="meta-code">{code}</span>
						<h2>{title}</h2>
						<p>{text}</p>
					</article>
				))}
			</section>

			<section class="quick-core hud-card">
				<p class="eyebrow">QUICK CORE</p>
				<h2>一个常用能量泛函</h2>
				<div class="formula-panel">
					<Formula math={energyFunctional} displayMode={true} />
				</div>
				<div class="button-row">
					<a class="button primary" href="/blog/mountain-pass-steady-state/">打开 Mountain Pass 笔记</a>
					<a class="button" href="/thesis#equation-core">查看主方程</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
