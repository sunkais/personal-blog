---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(840px, calc(100% - 2rem));
				padding-top: 3rem;
			}
			.prose { color: var(--text-primary); }
			.title {
				margin-bottom: 2rem;
				padding-bottom: 1.4rem;
				border-bottom: 1px solid var(--glass-border);
			}
			.title h1 {
				margin: 0;
				font-size: 2.8rem;
				background: linear-gradient(135deg, var(--electric-soft) 0%, var(--text-bright) 70%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.date {
				margin-bottom: 0.7rem;
				color: var(--text-muted);
				font-size: 0.92rem;
				font-family: "Courier New", "Consolas", monospace;
			}
			.last-updated-on { margin-top: 0.25rem; }

			.prose :global(p),
			.prose :global(ul),
			.prose :global(ol) { color: var(--text-secondary); }

			.prose :global(h2) {
				margin-top: 2.5rem;
				color: var(--electric-soft);
				font-family: "Courier New", "Consolas", monospace;
				letter-spacing: 0.03em;
			}
			.prose :global(h3) {
				margin-top: 1.8rem;
				color: var(--text-bright);
			}
			.prose :global(a) { color: var(--electric); text-underline-offset: 0.18em; }

			.prose :global(.katex-display) {
				margin: 1.2rem 0;
				padding: 1rem 1.2rem;
				border: 1px solid var(--glass-border);
				border-radius: 6px;
				background: rgba(7, 17, 31, 0.55);
				position: relative;
			}
			.prose :global(.katex-display)::before {
				content: "EQ";
				position: absolute;
				top: -0.55rem;
				left: 0.8rem;
				font-family: "Courier New", "Consolas", monospace;
				font-size: 0.6rem;
				color: var(--electric-dim);
				letter-spacing: 0.14em;
				background: var(--base);
				padding: 0 0.4rem;
			}

			.prose :global(hr) { margin: 2rem 0; }

			.prose :global(blockquote) {
				margin: 1.5rem 0;
				padding: 0.8rem 0 0.8rem 1.2rem;
				border-left: 3px solid var(--electric);
				background: rgba(15, 23, 42, 0.5);
				border-radius: 0 6px 6px 0;
			}

			@media (max-width: 720px) {
				main {
					width: min(100% - 1.25rem, 840px);
					padding-top: 2rem;
				}
				.title h1 { font-size: 2rem; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && <div class="last-updated-on">最后更新于 <FormattedDate date={updatedDate} /></div>}
						</div>
						<h1>{title}</h1>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
