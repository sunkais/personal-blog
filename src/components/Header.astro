---
import { NEXUS_URL, SITE_NAME_CN, SITE_NAME_EN } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav>
		<a class="brand" href="/" aria-label="回到首页">
			<span>{SITE_NAME_CN}</span>
			<small>{SITE_NAME_EN}</small>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">数学笔记</HeaderLink>
			<a href="/#thesis">论文书桌</a>
			<a href="/#tools">工具手札</a>
			<a href="/#projects">项目小径</a>
			<HeaderLink href="/about">关于我</HeaderLink>
			<a href={NEXUS_URL} target="_blank" rel="noreferrer">Nexus ↗</a>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0.8rem 1.25rem;
		border-bottom: 1px solid var(--line);
		background: color-mix(in srgb, var(--paper) 88%, transparent);
		backdrop-filter: blur(14px);
	}

	.brand {
		display: grid;
		gap: 0.08rem;
		color: var(--ink);
		line-height: 1.1;
		text-decoration: none;
	}
	.brand span {
		font-size: 1.05rem;
		font-weight: 700;
	}
	.brand small {
		color: var(--muted);
		font-size: 0.72rem;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1120px, 100%);
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.25rem 0.75rem;
	}
	.internal-links a {
		flex: 0 0 auto;
		padding: 0.35rem 0.15rem;
		border-bottom: 1px solid transparent;
		color: var(--muted);
		font-size: 0.92rem;
		text-decoration: none;
		transition:
			color 160ms ease,
			border-color 160ms ease;
	}
	.internal-links a:hover,
	.internal-links a.active {
		border-bottom-color: var(--leaf);
		color: var(--ink);
	}
	@media (max-width: 760px) {
		.site-header {
			position: static;
			padding: 0.85rem 1rem;
		}
		nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.7rem;
		}
		.internal-links {
			display: grid;
			grid-template-columns: repeat(3, max-content);
			justify-content: flex-start;
			gap: 0.25rem 0.95rem;
			width: 100%;
			max-width: 100%;
		}
		.internal-links a {
			font-size: 0.9rem;
		}
	}
</style>
