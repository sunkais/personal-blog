---
import { NEXUS_URL, SITE_NAME_CN, SITE_NAME_EN } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav>
		<a class="brand" href="/" aria-label="回到首页">
			<span class="brand-cn">{SITE_NAME_EN}</span>
			<span class="brand-en">{SITE_NAME_CN} · Research Node</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Lab</HeaderLink>
			<HeaderLink href="/thesis">Archive</HeaderLink>
			<HeaderLink href="/blog">Notes</HeaderLink>
			<HeaderLink href="/math">Formula</HeaderLink>
			<HeaderLink href="/ai">Workflow</HeaderLink>
			<HeaderLink href="/projects">项目</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<a href={NEXUS_URL} target="_blank" rel="noreferrer" class="nexus-link">Nexus / 小屋 ↗</a>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0.7rem 1.25rem;
		border-bottom: 1px solid var(--glass-border);
		background: rgba(7, 17, 31, 0.88);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(1120px, 100%);
		margin: 0 auto;
	}

	.brand {
		display: grid;
		gap: 0.05rem;
		color: var(--text-primary);
		text-decoration: none;
		line-height: 1.2;
	}

	.brand-cn {
		font-size: 1rem;
		font-weight: 700;
		color: var(--electric-soft);
		letter-spacing: 0.06em;
		font-family: "Courier New", "Consolas", monospace;
	}

	.brand-en {
		font-size: 0.68rem;
		color: var(--text-muted);
		letter-spacing: 0.08em;
	}

	.internal-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 0.15rem 0.6rem;
	}

	.internal-links a {
		flex: 0 0 auto;
		padding: 0.3rem 0.5rem;
		border: 1px solid transparent;
		border-radius: 4px;
		color: var(--text-secondary);
		font-size: 0.88rem;
		text-decoration: none;
		transition: all 180ms ease;
		letter-spacing: 0.03em;
	}

	.internal-links a:hover {
		border-color: var(--glass-border);
		background: rgba(76, 201, 240, 0.06);
		color: var(--electric-soft);
	}

	.internal-links a.active {
		border-color: var(--glass-border);
		background: rgba(76, 201, 240, 0.1);
		color: var(--electric);
		font-weight: 700;
	}

	.nexus-link {
		color: var(--violet) !important;
	}
	.nexus-link:hover {
		color: var(--violet) !important;
		border-color: var(--violet-glow) !important;
	}

	@media (max-width: 760px) {
		.site-header {
			position: static;
			padding: 0.75rem 1rem;
		}
		nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.6rem;
		}
		.internal-links {
			display: grid;
			grid-template-columns: repeat(3, max-content);
			justify-content: flex-start;
			gap: 0.2rem 0.7rem;
			width: 100%;
		}
		.internal-links a { font-size: 0.85rem; }
	}
</style>
