---
import { NEXUS_URL, SITE_NAME_EN } from '../consts';
---

<footer>
	<div class="footer-inner">
		<div class="footer-info">
			<p class="footer-brand">{SITE_NAME_EN}</p>
			<p>&copy; 2026 SKS · Research Lab</p>
		</div>
		<div class="footer-links">
			<a href="/">Lab</a>
			<a href="/thesis">Archive</a>
			<a href="/blog">Notes</a>
			<a href="/math">Formula Lab</a>
			<a href="/ai">AI Workflow</a>
			<a href="/projects">项目</a>
			<a href="/about">关于</a>
			<a href={NEXUS_URL} target="_blank" rel="noreferrer">Nexus Node ↗</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 3rem 1rem 4rem;
		border-top: 1px solid var(--glass-border);
		background: rgba(7, 17, 31, 0.5);
	}
	.footer-inner {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		width: min(1120px, 100%);
		margin: 0 auto;
	}
	.footer-brand {
		font-family: "Courier New", "Consolas", monospace;
		font-weight: 700;
		color: var(--electric-soft);
		letter-spacing: 0.06em;
		margin-bottom: 0.3rem;
	}
	.footer-info p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.88rem;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem 1rem;
	}
	.footer-links a {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.88rem;
		transition: color 160ms ease;
	}
	.footer-links a:hover { color: var(--electric-soft); }
	@media (max-width: 720px) {
		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
			gap: 1.5rem;
		}
	}
</style>
