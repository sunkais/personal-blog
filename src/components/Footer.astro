---
import { NEXUS_URL } from '../consts';

const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} 孙开松。松间笔记 Sunkais Garden。</p>
		<div class="footer-links">
			<a href="/blog">笔记集合</a>
			<a href="/math">数学</a>
			<a href="/physics">物理</a>
			<a href="/ai">AI 手札</a>
			<a href="/thesis">论文书桌</a>
			<a href="/projects">项目</a>
			<a href="/about">关于</a>
			<a href={NEXUS_URL} target="_blank" rel="noreferrer">Nexus ↗</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 3.5rem 1rem 4rem;
		border-top: 1px solid var(--line);
		color: var(--muted);
	}
	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(1120px, 100%);
		margin: 0 auto;
	}
	p {
		margin: 0;
	}
	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}
	.footer-links a {
		color: var(--muted);
		text-decoration: none;
	}
	.footer-links a:hover {
		color: var(--ink);
	}
	@media (max-width: 720px) {
		.footer-inner {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
